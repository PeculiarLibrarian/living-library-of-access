{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },

    "build#@padi/config-eslint": {
      "outputs": []
    },

    "build#@padi/config-ts": {
      "outputs": []
    },

    "test": {
      "dependsOn": ["build"]
    },

    "lint": {},

    "docker:build": {
      "dependsOn": ["build"]
    }
  }
}
